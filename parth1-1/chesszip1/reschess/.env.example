# ============================================================
# ICA Operations Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# Application
NEXT_PUBLIC_APP_NAME=Indian Chess Academy
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to your prod domain

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ica?retryWrites=true&w=majority

# JWT Secrets — use a 64-char random string for each
# Generate: openssl rand -base64 64
JWT_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string

# Razorpay
# Get from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# SMTP Email (Gmail example — use an App Password, not your real password)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=noreply@indianchessacademy.com
